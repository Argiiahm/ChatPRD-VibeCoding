@import "tailwindcss";

@theme {
  --color-background: #020617;
  --color-foreground: #f8fafc;
  --color-card: rgba(30, 41, 59, 0.5);
  --color-card-hover: rgba(51, 65, 85, 0.5);
  --color-primary: #6366f1;
  --color-primary-hover: #818cf8;
  --color-secondary: #1e293b;
  --color-secondary-hover: #334155;
  --color-accent: #a855f7;
  --blur-xs: 2px;
}

@layer base {
  body {
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }
}

@layer components {
  .glass {
    @apply bg-card backdrop-blur-md border border-slate-700/50 rounded-xl shadow-xl transition-all duration-300;
  }
  
  .glass-hover {
    @apply hover:bg-card-hover hover:border-slate-600/50;
  }

  .btn-primary {
    @apply px-6 py-3 bg-primary text-white rounded-lg font-semibold hover:bg-primary-hover shadow-lg shadow-primary/20 transition-all active:scale-95 disabled:opacity-50 disabled:pointer-events-none;
  }

  .btn-secondary {
    @apply px-4 py-2 bg-secondary text-slate-300 rounded-lg hover:bg-secondary-hover border border-slate-700 transition-all active:scale-95;
  }

  .input-field {
    @apply w-full bg-slate-900/50 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all text-slate-200 placeholder:text-slate-500;
  }
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background-color: transparent;
}

::-webkit-scrollbar-thumb {
  @apply bg-slate-800 rounded-full hover:bg-slate-700;
}

/* Markdown Styles */
.prose {
  @apply text-slate-300 max-w-none;
}

.prose h1, .prose h2, .prose h3 {
  @apply text-white font-bold mb-4 mt-6;
}

.prose h1 { @apply text-3xl; }
.prose h2 { @apply text-2xl border-b border-slate-800 pb-2; }
.prose h3 { @apply text-xl; }

.prose p { @apply mb-4 leading-relaxed; }

.prose ul { @apply list-disc list-inside mb-4 space-y-2; }

.prose code {
  @apply bg-slate-800 px-1.5 py-0.5 rounded text-primary text-sm font-mono;
}

.prose pre {
  @apply bg-slate-900 p-4 rounded-xl border border-slate-800 overflow-x-auto my-6;
}
